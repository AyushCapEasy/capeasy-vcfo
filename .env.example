# vCFO MIS Engine — environment template (SAFE TO COMMIT: placeholders only)
# Copy to .env.local and fill the three SECRET values for project `capeasy-vcfo`.
# HARD RULE (Build Plan §3): use ONLY credentials for project ref rsaztdwxrzgyxkvxrqrt.
# Never paste any other Supabase/GitHub key here. service_role is SERVER-ONLY.

# --- Non-secret (already known from Build Plan §2) ---
NEXT_PUBLIC_SUPABASE_URL=https://rsaztdwxrzgyxkvxrqrt.supabase.co
SUPABASE_PROJECT_REF=rsaztdwxrzgyxkvxrqrt
SUPABASE_REGION=ap-south-1

# --- Secrets (operator must provide; do NOT commit real values) ---
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
# Direct connection string. Host is derivable from the ref; only the password is secret.
DATABASE_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@db.rsaztdwxrzgyxkvxrqrt.supabase.co:5432/postgres

# --- Zoho Books (M-Zoho, D-014) — own-firm sales-side connector. SECRETS: .env.local only, never here. ---
# DC = your Zoho data center: in (India), com, eu, com.au, jp, ca, sa. Indian orgs are usually `in`.
ZOHO_DC=in
ZOHO_CLIENT_ID=REPLACE_WITH_ZOHO_CLIENT_ID
ZOHO_CLIENT_SECRET=REPLACE_WITH_ZOHO_CLIENT_SECRET
# Filled by `npx tsx scripts/zoho-auth.mts <grant_code>` (exchanges a short-lived grant code). Do NOT hand-edit.
ZOHO_REFRESH_TOKEN=REPLACE_WITH_ZOHO_REFRESH_TOKEN
ZOHO_ORG_ID=REPLACE_WITH_ZOHO_ORG_ID
